<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Go Back</title>

<style>
    body {
        margin: 0;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: black;
        font-family: Impact, Arial Black, sans-serif;
        color: white;
    }

    h1 {
        font-size: 100px;
        animation: flash 0.6s infinite alternate;
    }

    @keyframes flash {
        from { color: red; }
        to { color: yellow; }
    }

    button {
        position: fixed;
        bottom: 20px;
        right: 20px;
        padding: 12px 24px;
        font-size: 20px;
        cursor: pointer;
        border: 2px solid white;
        background: black;
        color: white;
    }
</style>
</head>

<body>
    <h1>GO BACK</h1>
    <button onclick="window.location.href='index.html'">Back</button>
</body>
</html>
